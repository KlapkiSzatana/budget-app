#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

echo "====================================================="
echo " Instalator aplikacji: Budżet Domowy (Home Budget)"
echo "====================================================="
echo ""

if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Instalacja wymaga uprawnień administratora (root).${NC}"
    echo "Prosze podać hasło, aby kontynuować instalację..."
    exec sudo bash "$0" "$@"
    exit $?
fi

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

INSTALL_DIR="/opt/BudgetApp"
DESKTOP_FILE="BudgetApp.desktop"
SYSTEM_APPLICATIONS_DIR="/usr/share/applications"

if [ ! -d "BudgetApp" ] || [ ! -f "budget.png" ] || [ ! -f "$DESKTOP_FILE" ]; then
    echo -e "${RED}Błąd: Brak wymaganych plików w tym katalogu!${NC}"
    echo "Upewnij się, ze instalator 'install.run' znajduje się w tym samym folderze co:"
    echo "  - katalog 'BudgetApp'"
    echo "  - plik 'budget.png'"
    echo "  - plik 'BudgetApp.desktop'"
    echo "Naciśnij Enter, aby zakończyć..."
    read -r
    exit 1
fi

echo "-> Przygotowywanie katalogu instalacyjnego w $INSTALL_DIR..."
mkdir -p "$INSTALL_DIR"
rm -rf "$INSTALL_DIR"/*

echo "-> Kopiowanie plików aplikacji..."
cp -r BudgetApp "$INSTALL_DIR/"
cp budget.png "$INSTALL_DIR/"
cp "$DESKTOP_FILE" "$INSTALL_DIR/"

echo "-> Konfigurowanie uprawnień dla programu..."
chmod +x "$INSTALL_DIR/BudgetApp/BudgetApp"

echo "-> Kopiowanie skrótu do menu aplikacji systemowych..."
cp "$DESKTOP_FILE" "$SYSTEM_APPLICATIONS_DIR/"
chmod 644 "$SYSTEM_APPLICATIONS_DIR/$DESKTOP_FILE"
chmod +x "$SYSTEM_APPLICATIONS_DIR/$DESKTOP_FILE"

echo "-> Odświeżanie menu aplikacji..."
if command -v update-desktop-database &> /dev/null; then
    update-desktop-database "$SYSTEM_APPLICATIONS_DIR"
fi

echo ""
echo -e "${GREEN}[SUKCES] Aplikacja Budżet Domowy została zainstalowana!${NC}"
echo "Skrót powinien być juz widoczny w Twoim menu aplikacji."
echo "Naciśnij Enter, aby zamknąć to okno..."
read -r
